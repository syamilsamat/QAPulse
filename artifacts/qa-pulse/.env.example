# Copy to .env.local (already gitignored) and fill in — never commit real values.

# Where the Playwright suite runs against: a local `pnpm dev` instance, or
# a deployed Replit dev workspace URL.
PLAYWRIGHT_BASE_URL=http://localhost:5173

# A real QAPulse login — used once by e2e/auth.setup.ts to create a reusable
# session. Use a dedicated test/demo account, not your personal admin login.
TEST_USER_EMAIL=
TEST_USER_PASSWORD=
