{
  "name": "@workspace/qa-automation",
  "version": "0.0.0",
  "private": true,
  "description": "Playwright automation for the QAPulse test suites in docs/test-plans — every test is linked to its Excel Case ID",
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test tests/smoke.spec.ts",
    "test:functional": "playwright test tests/functional.spec.ts",
    "test:negative": "playwright test tests/negative.spec.ts",
    "test:e2e": "playwright test tests/e2e.spec.ts",
    "report": "playwright show-report",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.57.0",
    "@types/node": "catalog:",
    "typescript": "~5.9.2"
  }
}
